    "code": "import sys\nimport re\n\ndef process_line(line):\n    # Split the line at '|' to ignore any distractor part\n    line = line.split('|')[0].strip()\n    match = re.search(r'(?P<name>\\w+) (?P<N>\\d+) (?:apples|candies|marbles) (?:and )?(?:buys|gives away|gave) (?P<M>\\d+)(?: marbles)?', line)\n    if match:\n        N = int(match.group('N'))\n        M = int(match.group('M'))\n        if 'buys' in line:\n            return N + M\n        elif 'gave' in line or 'gives away' in line:\n            return N - M if M <= N else 'INVALID'\n    return 'INVALID'\n\nif __name__ == '__main__':\n    input = sys.stdin.read().strip().split('\\n')\n    t = int(input[0])\n    results = []\n    for i in range(1, t + 1):\n        results.append(process_line(input[i]))\n    print('\\n'.join(map(str, results)))",
