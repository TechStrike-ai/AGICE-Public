    "code": "import sys\n\ndef process_sentence(sentence):\n    # Split on '|' to ignore distractors\n    main_part = sentence.split('|')[0].strip()\n    # Identify the pattern\n    if 'has' in main_part and 'buys' in main_part:\n        # Pattern 1: <Name> has N apples and buys M more.\n        parts = main_part.split()\n        N = int(parts[parts.index('has') + 1])\n        M = int(parts[parts.index('buys') + 1])\n        return N + M\n    elif 'had' in main_part and 'gave' in main_part:\n        # Pattern 2: <Name> had N candies and gave M away.\n        parts = main_part.split()\n        N = int(parts[parts.index('had') + 1])\n        M = int(parts[parts.index('gave') + 1])\n        return N - M if M <= N else 'INVALID'\n    elif 'has' in main_part and 'gives away' in main_part:\n        # Pattern 3: <Name> has N marbles and gives away M marbles.\n        parts = main_part.split()\n        N = int(parts[parts.index('has') + 1])\n        M = int(parts[parts.index('gives') + 2])\n        return N - M if M <= N else 'INVALID'\n    return 'INVALID'\n\nif __name__ == '__main__':\n    input = sys.stdin.read().strip().split('\\n')\n    t = int(input[0])\n    results = []\n    for i in range(1, t + 1):\n        result = process_sentence(input[i])\n        results.append(result)\n    for res in results:\n        print(res)",
