    "code": "import sys\n\ndef process_sentence(sentence):\n    # Split the sentence at the '|' character to ignore distractors\n    sentence = sentence.split('|')[0].strip()\n    parts = sentence.split()\n    name = parts[0]\n    N = int(parts[2])\n    M = int(parts[-2])\n    if 'buys' in sentence:\n        # Pattern 1: \"<Name> has N apples and buys M more.\"\n        return N + M\n    elif 'gave' in sentence:\n        # Pattern 2: \"<Name> had N candies and gave M away.\"\n        if M <= N:\n            return N - M\n        else:\n            return 'INVALID'\n    elif 'gives' in sentence:\n        # Pattern 3: \"<Name> has N marbles and gives away M marbles.\"\n        if M <= N:\n            return N - M\n        else:\n            return 'INVALID'\n    return 'INVALID'\n\nif __name__ == '__main__':\n    input = sys.stdin.read().strip().split('\\n')\n    t = int(input[0])\n    results = []\n    for i in range(1, t + 1):\n        result = process_sentence(input[i])\n        results.append(result)\n    print('\\n'.join(map(str, results)))",
