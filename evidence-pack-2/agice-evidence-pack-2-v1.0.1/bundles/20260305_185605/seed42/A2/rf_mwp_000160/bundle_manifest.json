    "code": "import sys\nimport re\n\ndef process_sentence(sentence):\n    # Ignore anything after '|' character\n    sentence = sentence.split('|')[0]\n    \n    # Use regex to find numbers\n    numbers = re.findall(r'-?\\d+', sentence)\n    if len(numbers) < 2:\n        return 'INVALID'\n    N = int(numbers[0])\n    M = int(numbers[1])\n    \n    if 'has' in sentence and 'buys' in sentence:\n        return N + M\n    elif 'had' in sentence and 'gave' in sentence:\n        return N - M if M <= N else 'INVALID'\n    elif 'has' in sentence and 'gives' in sentence:\n        return N - M if M <= N else 'INVALID'\n    return 'INVALID'\n\nif __name__ == '__main__':\n    input = sys.stdin.read().strip().split('\\n')\n    t = int(input[0])\n    results = []\n    for i in range(1, t + 1):\n        result = process_sentence(input[i])\n        results.append(result)\n    print('\\n'.join(map(str, results)))",
