    "code": "import sys\nimport re\n\ndef process_sentence(sentence):\n    # Remove any distractor part after '|'\n    sentence = sentence.split('|')[0].strip()\n    # Use regex to find numbers\n    numbers = re.findall(r'-?\\d+', sentence)\n    if len(numbers) < 2:\n        return 'INVALID'\n    N = int(numbers[0])\n    M = int(numbers[1])\n    if 'has' in sentence and 'buys' in sentence:\n        return N + M\n    elif 'had' in sentence or 'gives' in sentence:\n        return N - M if M <= N else 'INVALID'\n    return 'INVALID'\n\nif __name__ == '__main__':\n    input = sys.stdin.read\n    data = input().strip().split('\\n')\n    t = int(data[0])\n    results = []\n    for i in range(1, t + 1):\n        result = process_sentence(data[i])\n        results.append(result)\n    print('\\n'.join(map(str, results)))",
