    "code": "import sys\n\ndef process_sentence(sentence):\n    # Split on '|' to ignore distractors\n    main_part = sentence.split('|')[0].strip()\n    # Identify the pattern\n    if 'has' in main_part and 'buys' in main_part:\n        # Pattern 1\n        parts = main_part.split()\n        name = parts[0]\n        N = int(parts[2])\n        M = int(parts[6])\n        return N + M\n    elif 'had' in main_part and 'gave' in main_part:\n        # Pattern 2\n        parts = main_part.split()\n        name = parts[0]\n        N = int(parts[2])\n        M = int(parts[6])\n        return N - M if M <= N else 'INVALID'\n    elif 'has' in main_part and 'gives' in main_part:\n        # Pattern 3\n        parts = main_part.split()\n        name = parts[0]\n        N = int(parts[2])\n        M = int(parts[6])\n        return N - M if M <= N else 'INVALID'\n    return 'INVALID'\n\nif __name__ == '__main__':\n    input = sys.stdin.read().strip().split('\\n')\n    t = int(input[0])\n    results = []\n    for i in range(1, t + 1):\n        result = process_sentence(input[i])\n        results.append(result)\n    print('\\n'.join(map(str, results)))",
