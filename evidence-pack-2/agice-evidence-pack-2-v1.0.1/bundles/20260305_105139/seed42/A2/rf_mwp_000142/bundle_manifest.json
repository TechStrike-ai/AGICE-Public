    "code": "import sys\nimport re\n\ndef process_sentence(sentence):\n    # Remove any distractor part after '|'\n    sentence = sentence.split('|')[0].strip()\n    # Use regex to find numbers\n    numbers = re.findall(r'-?\\d+', sentence)\n    if len(numbers) < 2:\n        return 'INVALID'\n    N = int(numbers[0])\n    M = int(numbers[1])\n    if 'buys' in sentence:\n        return N + M\n    elif 'gave' in sentence:\n        if M <= N:\n            return N - M\n        else:\n            return 'INVALID'\n    elif 'gives' in sentence:\n        if M <= N:\n            return N - M\n        else:\n            return 'INVALID'\n    return 'INVALID'\n\nif __name__ == '__main__':\n    input = sys.stdin.read().strip().split('\\n')\n    t = int(input[0])\n    results = []\n    for i in range(1, t + 1):\n        result = process_sentence(input[i])\n        results.append(result)\n    print('\\n'.join(map(str, results)))",
