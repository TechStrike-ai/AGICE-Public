    "code": "import sys\n\ndef process_sentence(sentence):\n    # Split the sentence at '|' if it exists\n    if '|' in sentence:\n        sentence = sentence.split('|')[0].strip()\n    \n    # Patterns matching\n    if 'has' in sentence and 'buys' in sentence:\n        parts = sentence.split('has')[-1].split('buys')\n        N = int(parts[0].strip().split()[0])\n        M = int(parts[1].strip().split()[0])\n        return N + M\n    elif 'had' in sentence and 'gave' in sentence:\n        parts = sentence.split('had')[-1].split('gave')\n        N = int(parts[0].strip().split()[0])\n        M = int(parts[1].strip().split()[0])\n        return N - M if M <= N else 'INVALID'\n    elif 'has' in sentence and 'gives away' in sentence:\n        parts = sentence.split('has')[-1].split('gives away')\n        N = int(parts[0].strip().split()[0])\n        M = int(parts[1].strip().split()[0])\n        return N - M if M <= N else 'INVALID'\n    return 'INVALID'\n\nif __name__ == '__main__':\n    input = sys.stdin.read().strip().split('\\n')\n    t = int(input[0])\n    results = []\n    for i in range(1, t + 1):\n        result = process_sentence(input[i])\n        results.append(result)\n    print('\\n'.join(map(str, results)))",
